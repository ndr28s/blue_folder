{
  "appId": "com.ndr28s.bluefolder",
  "productName": "Blue Folder",
  "asar": false,
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "extraResources": [
    {
      "from": "dist/server",
      "to": "server",
      "filter": ["**/*"]
    }
  ],
  "publish": null,
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Blue Folder",
    "runAfterFinish": true,
    "installerIcon": "assets/appIcon.ico",
    "uninstallerIcon": "assets/appIcon.ico",
    "installerHeaderIcon": "assets/appIcon.ico"
  },
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "dir", "arch": ["x64"] }
    ],
    "icon": "assets/appIcon.ico"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg"
  }
}